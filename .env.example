# Naver Search API
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Google Custom Search API
GOOGLE_API_KEY=your_google_api_key
SEARCH_ENGINE_ID=your_google_search_engine_id

# OpenAI API
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_BASIC=gpt-4o-mini-2024-07-18
OPENAI_MODEL_ADVANCED=gpt-4o-mini-2024-07-18

# Gmail SMTP
GMAIL_USER=your_account@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Recipients (comma separated)
REPORT_RECIPIENTS=first@example.com

SAFETY_ALERT_RECIPIENTS=
ENABLE_0404_ALERTS=true
DEBUG_MODE=false
DRY_RUN=false
TIME_WINDOW_HOURS=24
MAX_ARTICLES_PER_CATEGORY=10
EMAIL_TOP_N=3
EMAIL_SUMMARY_MAX_CHARS=140
CRON_SECRET=replace_with_strong_secret

# Upstash Redis (실행 간 중복 제거용 - Vercel 대시보드 Marketplace > Upstash 연동 후 자동 주입)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
